# Copy to `.env.local` for local dev. On Vercel, set in Project → Settings → Environment Variables.
# NEVER commit `.env.local`.

# ── Supabase Auth (required in production secure mode) ──
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Super security mode (REQUIRED for production) ──
# When true: browser never sees GAS URL; all API via /api/gas-proxy + login JWT.
VITE_SECURE_GAS=true
VITE_REQUIRE_SUPABASE_AUTH=true

# ── Server-only (Vercel + local dev middleware — NO VITE_ prefix) ──
# Full Apps Script /exec URL — never expose in client code.
GAS_WEBAPP_URL=https://script.google.com/macros/s/AKfycbySEk9JzO9xe6dSKhXhtP-J3oRiBHW1e6MTgQuNit-AK5VDHAtnolaIoFAGD7_6S_PQBg/exec
# Same value as API_SECRET in GAS Script Properties (min 32 random chars).
GAS_API_SECRET=generate-a-long-random-secret-min-32-chars
