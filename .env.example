# Copy to `.env.local` for local dev. On Vercel → Project Settings → Environment Variables.
# NEVER commit `.env.local`.

# ── Supabase (OPTIONAL — email/password login only) ──
# Emptykan jika pakai akun demo dev. Tidak wajib untuk akses data sheet.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Secure GAS via Vercel proxy (otomatis aktif di *.vercel.app) ──
# Set false untuk dev lokal langsung ke GAS.
# VITE_SECURE_GAS=false

# ── Server-only di Vercel (tanpa prefix VITE_) ──
GAS_WEBAPP_URL=https://script.google.com/macros/s/AKfycbwSQT0h8BG4M1J26_TeY4THMTGREQ0Zf5hrIg6c0cVSC0s_zgNkElQ4ckdQ-fnpPrBx1w/exec

# Opsional — sama dengan API_SECRET di GAS Script Properties (aktifkan proteksi penuh)
# GAS_API_SECRET=
