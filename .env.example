# Copy to `.env.local` for local dev. On Vercel → Project Settings → Environment Variables.
# NEVER commit `.env.local`.

# ── Auth gate (Hub Portal SSO) ──
# Production: set true so direct visits without a Hub session are blocked.
# VITE_AUTH_ENABLED=true

# Hub Portal (login only happens here)
# VITE_HUB_PORTAL_URL=https://sustainability-hub-portal-eight.vercel.app
# VITE_HUB_LOGIN_PATH=/login

# Dev only — show local email/password form instead of redirecting to Hub
# VITE_ALLOW_LOCAL_LOGIN=true

# ── Supabase (same project as Hub Portal) ──
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Set false untuk dev lokal langsung ke GAS.
# VITE_SECURE_GAS=false

# Localhost: API via /api/gas-proxy (default, same as Vercel). Set false to use legacy /gas-api rewrite.
# VITE_LOCAL_GAS_PROXY=false

# ── Server-only di Vercel (tanpa prefix VITE_) ──
GAS_WEBAPP_URL=https://script.google.com/macros/s/AKfycbyn7QsagneVRVhfTCls2U1jq5YwRolVXxuE4i9X8vHKuxlzQwwbGAuMjJ8klwnBGidmrQ/exec

# Opsional — sama dengan API_SECRET di GAS Script Properties (aktifkan proteksi penuh)
# GAS_API_SECRET=
